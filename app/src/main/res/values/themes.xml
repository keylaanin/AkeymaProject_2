<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AkeymaEWallet" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/green_accent</item>
        <item name="colorOnSecondary">@color/dark_text</item>
        <item name="android:windowBackground">@color/page_bg</item>
        <item name="android:statusBarColor">@color/statusBar</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="Theme.AkeymaEWallet.Splash" parent="Theme.AkeymaEWallet">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Button Style -->
    <style name="GreenButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/green_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- OutlineButton -->
    <style name="OutlineGreenButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/green_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/green_primary</item>
    </style>

    <!-- Card Style -->
    <style name="GreenCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>
</resources>