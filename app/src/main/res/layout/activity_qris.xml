<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient_green_white"
        app:title="QRIS Payment"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan QR Berikut untuk Menerima Pembayaran"
                android:textColor="@color/green_dark"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- QR Image -->
            <androidx.cardview.widget.CardView
                android:layout_width="260dp"
                android:layout_height="260dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/ivQrCode"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    android:scaleType="fitCenter" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvQrInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AKEYMA E-WALLET&#10;8812 3456 7890"
                android:gravity="center"
                android:textColor="@color/green_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Nominal Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilQrisAmount"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nominal (opsional)"
                app:boxStrokeColor="@color/green_primary"
                app:prefixText="Rp "
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etQrisAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateQr"
                style="@style/GreenButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="GENERATE QR"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanQr"
                style="@style/OutlineGreenButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="SCAN QR MERCHANT" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>