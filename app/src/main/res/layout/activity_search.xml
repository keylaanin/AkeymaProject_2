<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:orientation="vertical">

    <!-- Search Toolbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/gradient_green_white" android:padding="12dp"
        android:orientation="horizontal" android:gravity="center_vertical">

        <ImageView android:id="@+id/btnBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_back" android:tint="@color/white"
            android:padding="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="8dp"
            android:hint="Cari transaksi, fitur..."
            app:boxStrokeColor="@color/white" app:hintTextColor="@color/white"
            app:boxBackgroundColor="#44FFFFFF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/white"
                android:inputType="text" android:imeOptions="actionSearch" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Quick Access Chips -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="12dp" android:scrollbars="none">
        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content" android:layout_height="wrap_content">
            <com.google.android.material.chip.Chip android:id="@+id/chipFavorite"
                style="@style/Widget.MaterialComponents.Chip.Entry"
                android:text="⭐ Favorit" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <com.google.android.material.chip.Chip android:id="@+id/chipRecent"
                style="@style/Widget.MaterialComponents.Chip.Entry"
                android:text="🕐 Terbaru" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <com.google.android.material.chip.Chip android:id="@+id/chipTopUp2"
                style="@style/Widget.MaterialComponents.Chip.Entry"
                android:text="💰 Top Up" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <com.google.android.material.chip.Chip android:id="@+id/chipTransfer"
                style="@style/Widget.MaterialComponents.Chip.Entry"
                android:text="💸 Transfer" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false" />
</LinearLayout>