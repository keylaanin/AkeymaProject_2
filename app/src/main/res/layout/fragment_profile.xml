<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Profile -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="200dp"
            android:background="@drawable/gradient_header">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:orientation="vertical" android:gravity="center">
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="80dp" android:layout_height="80dp"
                    android:src="@drawable/ic_profile"
                    app:civ_border_width="3dp" app:civ_border_color="@color/white" />
                <TextView android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/white" android:textSize="18sp"
                    android:textStyle="bold" android:layout_marginTop="10dp" />
                <TextView android:id="@+id/tvProfileEmail"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#CCFFFFFF" android:textSize="13sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Menu Items -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Customer Service -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp" app:cardElevation="3dp">
                <LinearLayout android:id="@+id/menuCS"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎧" android:textSize="22sp" android:layout_marginEnd="16dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Customer Service"
                        android:textSize="15sp" android:textColor="@color/dark_text" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/gray_text" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Keamanan -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp" app:cardElevation="3dp">
                <LinearLayout android:id="@+id/menuSecurity"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒" android:textSize="22sp" android:layout_marginEnd="16dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Keamanan"
                        android:textSize="15sp" android:textColor="@color/dark_text" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/gray_text" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logout -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/error"
                android:text="KELUAR"
                android:textColor="@color/white"
                style="@style/GreenButton" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>